# Copy this file to .env.local (gitignored) and fill in real values.
# Vite reads VITE_-prefixed vars and bakes them into the client bundle at build time.
#
# ⚠ These values are PUBLIC by deployment — they ship inside the client JS
# and are visible in DevTools → Sources to anyone using the deployed site.
# Hiding them from the Settings UI does NOT make them secret. For a real
# multi-user product, move the Azure key to a server-side proxy (Cloudflare
# Worker / Azure Function) and let the PWA POST images to the proxy instead.

# Azure Document Intelligence — receipt OCR
VITE_AZURE_DOC_INTEL_ENDPOINT=https://YOUR-RESOURCE.cognitiveservices.azure.com
VITE_AZURE_DOC_INTEL_KEY=your-32-character-subscription-key
VITE_AZURE_DOC_INTEL_MODEL=prebuilt-receipt
VITE_AZURE_DOC_INTEL_API_VERSION=2024-11-30
