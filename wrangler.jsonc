{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "budget-sparrow",
  "compatibility_date": "2026-05-20",
  "observability": {
    "enabled": true
  },
  "main": ".svelte-kit/cloudflare/_worker.js",
  "assets": {
    "binding": "ASSETS",
    "directory": ".svelte-kit/cloudflare"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  // Custom domain. The Worker still answers on its workers.dev subdomain
  // (Cloudflare auto-provisions it), and adds budgetsparrow.craigboren.com
  // as a primary custom domain. This requires craigboren.com to be a Zone
  // in the same Cloudflare account; wrangler creates the CNAME + SSL cert
  // on the next deploy.
  "routes": [
    { "pattern": "budgetsparrow.craigboren.com", "custom_domain": true }
  ],
  // Plaintext runtime variables. These are checked into the public repo,
  // so DO NOT put anything sensitive here. They are the source of truth
  // for the Worker on every `wrangler deploy` — dashboard-added plaintext
  // vars get wiped on the next CI deploy.
  //
  // Secrets live separately (Cloudflare dashboard → Secrets, or
  // `wrangler secret put`). Deploys never touch them. The two we keep
  // as Secrets:
  //   AZURE_DOC_INTEL_ENDPOINT  (URL embeds the resource name — treat as private)
  //   AZURE_DOC_INTEL_KEY       (subscription key)
  "vars": {
    "AZURE_DOC_INTEL_MODEL": "prebuilt-receipt",
    "AZURE_DOC_INTEL_API_VERSION": "2024-11-30",
    "ALLOWED_ORIGINS": "https://budgetsparrow.craigboren.com"
  }
}
